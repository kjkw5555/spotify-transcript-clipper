{
  "manifest_version": 3,
  "name": "Spotify Transcript Extractor",
  "version": "1.0.0",
  "description": "Spotifyポッドキャストの「聴きながら読む」トランスクリプトを抽出・コピーします",
  "permissions": ["scripting", "activeTab", "clipboardWrite"],
  "host_permissions": ["https://open.spotify.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
